      </div>
      ${t.rules.length?`<div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:6px;">${t.rules.map(r=>`<span style="font-size:10px;padding:2px 7px;border-radius:20px;background:${BAD.includes(r)?'rgba(255,49,92,0.1)':'rgba(0,229,160,0.08)'};color:${BAD.includes(r)?'var(--danger)':'var(--accent)'};border:1px solid ${BAD.includes(r)?'rgba(255,49,92,0.2)':'rgba(0,229,160,0.15)'};font-family:Space Mono,monospace;">${r}</span>`).join('')}</div>`:''}

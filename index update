// ── JOURNAL ────────────────────────────────────────────────────
let trades=[],tradeType=null,ruleTags=[];
const BAD=['Chased breakout','Ignored SL','Traded first 3 candles','Revenge trade'];
let guardrailOverride=false,pendingTrade=null;

function setEntryDate(){const d=getISTDate();const str=formatDate(d);document.getElementById('entry-date-display').textContent=str;return str;}
setEntryDate();

function setType(t){tradeType=t;document.getElementById('type-call').classList.toggle('selected-yes',t==='CALL');document.getElementById('type-put').classList.toggle('selected-yes',t==='PUT');calcPnl();}

function calcPnl(){
  const ep=parseFloat(document.getElementById('entry-price').value);
  const xp=parseFloat(document.getElementById('exit-price').value);
  const qty=parseFloat(document.getElementById('entry-qty').value)||0;
  const sl=parseFloat(document.getElementById('entry-sl').value);
  const disp=document.getElementById('pnl-display');
  if(!ep||!xp||!qty){disp.style.display='none';return;}
  const ppu=xp-ep;const total=ppu*qty;
  const prof=total>=0;
  disp.style.display='block';
  disp.style.border=`1px solid ${prof?'rgba(0,229,160,0.3)':'rgba(255,49,92,0.3)'}`;
  disp.style.background=prof?'rgba(0,229,160,0.04)':'rgba(255,49,92,0.04)';
  const pv=document.getElementById('pnl-value');pv.textContent=`${prof?'+':''}₹${total.toFixed(0)}`;pv.style.color=prof?'var(--accent)':'var(--danger)';
  let bd=`${qty} units · ₹${ppu.toFixed(2)}/unit`;
  if(sl&&ep){const risk=Math.abs(ep-sl)*qty;bd+=` · SL risk: ₹${risk.toFixed(0)}`;}
  document.getElementById('pnl-breakdown').textContent=bd;
}

function toggleRuleTag(el){const r=el.dataset.rule;if(ruleTags.includes(r)){ruleTags=ruleTags.filter(x=>x!==r);el.classList.remove('selected-yes','selected-no');}else{ruleTags.push(r);el.classList.add(BAD.includes(r)?'selected-no':'selected-yes');}}

// ── GUARDRAILS ─────────────────────────────────────────────────
function checkGuardrails(trade){
  const ist=getISTDate();const h=ist.getHours(),m=ist.getMinutes();const tot=h*60+m;
  const warnings=[];
  if(tot>=9*60+15&&tot<9*60+30)warnings.push('🕐 You are trying to trade in the first 3 candles (9:15–9:30). This is your lowest probability zone.');
  const todayTrades=trades.filter(t=>t.date===todayStr());
  const losses=todayTrades.filter(t=>t.totalPnl!==null&&t.totalPnl<0);
  if(losses.length>=2)warnings.push(`🔴 You have already lost ${losses.length} trades today. Your rules say: protect your capital. Are you revenge trading?`);
  const todayBreaks=todayTrades.reduce((s,t)=>s+t.breaks.length,0);
  if(todayBreaks>=3)warnings.push(`⚠️ You have broken ${todayBreaks} rules today already. Trading more may compound the damage.`);
  if(trade.rules.some(r=>BAD.includes(r)))warnings.push('🚨 You selected a rule violation tag. Are you sure you want to log this trade?');
  return warnings;
}

function addTrade(){
  if(!tradeType){showToast('Select CALL or PUT first',true);return;}
  const ep=parseFloat(document.getElementById('entry-price').value);
  const xp=parseFloat(document.getElementById('exit-price').value);
  const qty=parseFloat(document.getElementById('entry-qty').value);
  if(!ep||!qty){showToast('Entry price & quantity required',true);return;}
  const ppu=xp?(xp-ep):null;
  const total=ppu!==null?ppu*qty:null;
  const trade={id:Date.now(),type:tradeType,date:todayStr(),entryTime:document.getElementById('entry-time').value||'—',exitTime:document.getElementById('exit-time').value||'—',entryPrice:ep,exitPrice:xp||null,sl:parseFloat(document.getElementById('entry-sl').value)||null,qty,totalPnl:total,result:total!==null?(total>=0?'WIN':'LOSS'):'OPEN',rules:[...ruleTags],breaks:ruleTags.filter(r=>BAD.includes(r)),note:document.getElementById('trade-note').value.trim()};
  const warns=checkGuardrails(trade);
  if(warns.length&&!guardrailOverride){pendingTrade=trade;showGuardrail(warns);return;}
  commitTrade(trade);
}

function showGuardrail(warns){
  document.getElementById('modal-msg').innerHTML=warns.join('<br><br>');
  document.getElementById('guardrail-modal').classList.add('show');
  // also show banner
  document.getElementById('guardrail-banner').style.display='block';
  document.getElementById('guardrail-banner-msg').innerHTML=warns[0];
}

function dismissGuardrail(override){
  document.getElementById('guardrail-modal').classList.remove('show');
  if(override&&pendingTrade){guardrailOverride=true;commitTrade(pendingTrade);pendingTrade=null;guardrailOverride=false;}else{pendingTrade=null;}
}

function commitTrade(trade){trades.unshift(trade);saveTrades();renderLog();updateStats();resetTradeForm();showToast('Trade logged ✅',false);renderGuardrailBanner();}

function renderGuardrailBanner(){
  const banner=document.getElementById('guardrail-banner');
  const todayT=trades.filter(t=>t.date===todayStr());
  const losses=todayT.filter(t=>t.totalPnl!==null&&t.totalPnl<0).length;
  const breaks=todayT.reduce((s,t)=>s+t.breaks.length,0);
  const msgs=[];
  if(losses>=2)msgs.push(`🔴 ${losses} losses today — protect your capital.`);
  if(breaks>=2)msgs.push(`⚠️ ${breaks} rule breaks today — discipline is slipping.`);
  if(msgs.length){banner.style.display='block';document.getElementById('guardrail-banner-title').textContent='⚠️ LIVE GUARDRAIL';document.getElementById('guardrail-banner-msg').innerHTML=msgs.join('<br>');}
  else banner.style.display='none';
}

function resetTradeForm(){tradeType=null;ruleTags=[];['type-call','type-put'].forEach(id=>document.getElementById(id).classList.remove('selected-yes','selected-no'));document.querySelectorAll('.rule-tag-btn').forEach(b=>b.classList.remove('selected-yes','selected-no'));['entry-time','exit-time','entry-price','entry-qty','entry-sl','exit-price','trade-note'].forEach(id=>{document.getElementById(id).value='';});document.getElementById('pnl-display').style.display='none';setEntryDate();}

function updateStats(){
  const has=trades.length>0;
  document.getElementById('journal-stats').style.display=has?'grid':'none';
  document.getElementById('trade-log-card').style.display=has?'block':'none';
  if(!has)return;
  const closed=trades.filter(t=>t.result!=='OPEN');
  const wins=closed.filter(t=>t.result==='WIN').length;
  const totalPnl=trades.reduce((s,t)=>s+(t.totalPnl||0),0);
  const breaks=trades.reduce((s,t)=>s+t.breaks.length,0);
  document.getElementById('stat-total').textContent=trades.length;
  document.getElementById('stat-wr').textContent=closed.length?Math.round((wins/closed.length)*100)+'%':'—';
  const pe=document.getElementById('stat-pnl');pe.textContent=(totalPnl>=0?'+':'')+'₹'+Math.round(totalPnl);pe.className='stat-value '+(totalPnl>=0?'accent':'danger');
  document.getElementById('stat-breaks').textContent=breaks;
}


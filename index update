function exportCSV(){
  if(!trades.length){showToast('No trades to export',true);return;}
  const h='Date,Type,Result,Entry Time,Exit Time,Entry Price,Exit Price,Qty,SL,P&L (₹),Rules,Note';
  const rows=trades.map(t=>[t.date,t.type,t.result,t.entryTime,t.exitTime,t.entryPrice,t.exitPrice||'',t.qty,t.sl||'',t.totalPnl!==null?Math.round(t.totalPnl):'',`"${t.rules.join(';')}"`,`"${t.note}"`].join(','));
  const csv=[h,...rows].join('\n');
  const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);a.download=`nifty-trades-${todayStr().replace(/\//g,'-')}.csv`;a.click();
  showToast('CSV exported ✅',false);
}


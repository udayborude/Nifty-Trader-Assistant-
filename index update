let lastAlertMin=-1;
setInterval(()=>{const ist=getISTDate();const h=ist.getHours(),m=ist.getMinutes(),key=h*60+m;if(key===lastAlertMin)return;lastAlertMin=key;
  if(h===9&&m===15){showToast('🔔 Market Open — Watch Only. No trades yet.',true);playAlert('bell');}
  if(h===9&&m===30){showToast('✅ 3 candles done. Direction forming. Stay patient.',false);playAlert('good');}
  if(h===10&&m===30){showToast('📈 Prime window open. Hunt your pullback.',false);playAlert('good');}
  if(h===13&&m===0){showToast('⚠️ Lunch hour — choppy. Reduce risk.',true);playAlert('warn');}
  if(h===15&&m===15){showToast('🔔 Close all positions. Session ending soon.',true);playAlert('danger');}
},15000);


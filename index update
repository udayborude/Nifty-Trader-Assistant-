<script>
// ── UTILS ──────────────────────────────────────────────────────
function getISTDate(){const n=new Date();const i=new Date(n.toLocaleString('en-US',{timeZone:'Asia/Kolkata'}));return i;}
function formatDate(d){const ist=d instanceof Date?d:new Date(d);return String(ist.getDate()).padStart(2,'0')+'/'+String(ist.getMonth()+1).padStart(2,'0')+'/'+ist.getFullYear();}
function todayStr(){return formatDate(getISTDate());}

// ── CLOCK ──────────────────────────────────────────────────────
function updateClock(){
  const ist=getISTDate();
  const h=String(ist.getHours()).padStart(2,'0'),m=String(ist.getMinutes()).padStart(2,'0'),s=String(ist.getSeconds()).padStart(2,'0');
  document.getElementById('clock').textContent=`${h}:${m}:${s}`;
  const tot=ist.getHours()*60+ist.getMinutes();
  const label=document.getElementById('session-label');
  const phases=[{id:'tl-pre',mn:0,mx:9*60+14},{id:'tl-open',mn:9*60+15,mx:9*60+29},{id:'tl-early',mn:9*60+30,mx:10*60+29},{id:'tl-prime',mn:10*60+30,mx:13*60},{id:'tl-lunch',mn:13*60+1,mx:14*60},{id:'tl-close',mn:14*60+1,mx:15*60+14},{id:'tl-end',mn:15*60+15,mx:15*60+30}];
  phases.forEach(p=>{const el=document.getElementById(p.id);if(!el)return;el.classList.remove('active','done');if(tot>=p.mn&&tot<=p.mx)el.classList.add('active');else if(tot>p.mx)el.classList.add('done');});
  if(tot<9*60+15)label.textContent='Pre-Market · Do your ritual';
  else if(tot<=9*60+29)label.textContent='🚫 No-Trade Zone · Watch only';
  else if(tot<=10*60+29)label.textContent='Direction forming · Be patient';
  else if(tot<=13*60)label.textContent='✅ Prime Window · Follow your rules';
  else if(tot<=14*60)label.textContent='⚠️ Lunch Chop · Reduce risk';
  else if(tot<=15*60+14)label.textContent='Late session · Stay disciplined';
  else if(tot<=15*60+30)label.textContent='🔔 Close all positions!';
  else label.textContent='Market Closed · Review your day';
}
setInterval(updateClock,1000);updateClock();

// ── TABS ───────────────────────────────────────────────────────
function switchTab(name,btn){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  if(btn)btn.classList.add('active');
  if(name==='analytics')renderAnalytics();
  if(name==='ailog')renderAIHistory();
}

// ── BELIEFS ────────────────────────────────────────────────────
function toggleBelief(el){el.classList.toggle('checked');const items=document.querySelectorAll('.belief-item');const checked=document.querySelectorAll('.belief-item.checked').length;const pct=Math.round((checked/items.length)*100);document.getElementById('belief-progress').style.width=pct+'%';document.getElementById('belief-label').textContent=`${checked} / ${items.length} beliefs acknowledged`;if(checked===items.length)showToast('✅ All beliefs aligned. You are ready.',false);}

// ── TEMP CHECK ─────────────────────────────────────────────────
const tempData={cold:{pct:5,cls:'selected',bg:'rgba(0,229,160,0.05)',border:'rgba(0,229,160,0.2)',msg:'🧊 Ice cold — perfect trading state. Stick to your plan.'},warm:{pct:35,cls:'selected',bg:'rgba(255,209,102,0.05)',border:'rgba(255,209,102,0.2)',msg:'🌤️ Warm and focused — solid state. Trust the EMA terrain.'},hot:{pct:67,cls:'selected-bad',bg:'rgba(255,107,53,0.05)',border:'rgba(255,107,53,0.2)',msg:'🔥 Overheated — halve your size. No revenge trades. Breathe.'},burnt:{pct:97,cls:'selected-bad',bg:'rgba(255,49,92,0.05)',border:'rgba(255,49,92,0.2)',msg:'💀 Burnt out — your edge is gone. Observe only today.'}};

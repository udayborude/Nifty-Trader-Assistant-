<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nifty Trading Assistant</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0c0f;--panel:#111418;--border:#1e2430;--accent:#00e5a0;--accent2:#ff6b35;--warn:#ffd166;--danger:#ff3a5c;--text:#e8edf5;--muted:#4a5568;--dim:#2d3748;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,229,160,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,160,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;}
.container{max-width:960px;margin:0 auto;padding:24px 16px;position:relative;z-index:1;}
header{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid var(--border);}
.logo-title{font-size:22px;font-weight:800;letter-spacing:-0.5px;}.logo-title span{color:var(--accent);}
.logo-sub{font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:2px;}
#clock{font-family:'Space Mono',monospace;font-size:26px;font-weight:700;color:var(--accent);letter-spacing:2px;}
#session-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:2px;margin-top:2px;font-family:'Space Mono',monospace;text-align:right;}
.tabs{display:flex;gap:4px;margin-bottom:24px;background:var(--panel);padding:4px;border-radius:10px;border:1px solid var(--border);flex-wrap:wrap;}
.tab{flex:1;min-width:80px;padding:10px 6px;background:transparent;border:none;color:var(--muted);font-family:'Syne',sans-serif;font-size:12px;font-weight:600;cursor:pointer;border-radius:7px;transition:all 0.2s;text-transform:uppercase;letter-spacing:1px;}
.tab.active{background:var(--bg);color:var(--accent);border:1px solid var(--border);}
.tab:hover:not(.active){color:var(--text);}
.panel{display:none;}.panel.active{display:block;}
.card{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:16px;}
.card-title{font-size:11px;text-transform:uppercase;letter-spacing:2px;color:var(--muted);font-family:'Space Mono',monospace;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.card-title::before{content:'';display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--accent);}
.field-label{font-size:10px;color:var(--muted);font-family:'Space Mono',monospace;letter-spacing:1.5px;margin-bottom:5px;text-transform:uppercase;}
.j-input{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-family:'Space Mono',monospace;font-size:13px;outline:none;transition:border-color 0.2s;}
.j-input:focus{border-color:var(--accent);}
.j-input::placeholder{color:var(--muted);}
.ans-btn{flex:1;padding:10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--muted);font-family:'Syne',sans-serif;font-weight:700;font-size:13px;cursor:pointer;transition:all 0.2s;letter-spacing:1px;}
.ans-btn:hover{border-color:var(--accent2);color:var(--text);}
.ans-btn.selected-yes{background:rgba(0,229,160,0.1);border-color:var(--accent);color:var(--accent);}
.ans-btn.selected-no{background:rgba(255,49,92,0.1);border-color:var(--danger);color:var(--danger);}
.btn{display:inline-flex;align-items:center;gap:6px;padding:10px 18px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s;letter-spacing:1px;text-transform:uppercase;}
.btn:hover{border-color:var(--accent);color:var(--accent);}
.btn-accent{background:var(--accent);color:#000;border-color:var(--accent);}
.btn-accent:hover{background:#00c888;color:#000;}
.btn-sm{padding:6px 12px;font-size:11px;}
.progress-bar{height:4px;background:var(--dim);border-radius:4px;margin-top:14px;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),#00b37a);border-radius:4px;transition:width 0.5s ease;}
.progress-label{font-size:11px;color:var(--muted);font-family:'Space Mono',monospace;margin-top:8px;text-align:right;}
.belief-item{display:flex;align-items:flex-start;gap:14px;padding:14px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:all 0.2s;}
.belief-item:last-child{border-bottom:none;}
.belief-item:hover{padding-left:6px;}
.belief-check{width:22px;height:22px;border:2px solid var(--dim);border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:all 0.3s;font-size:12px;}
.belief-item.checked .belief-check{border-color:var(--accent);background:var(--accent);color:#000;}
.belief-text{font-size:15px;line-height:1.5;color:var(--text);font-weight:600;}
.belief-sub{font-size:12px;color:var(--muted);margin-top:3px;font-weight:400;font-family:'Space Mono',monospace;}
.belief-item.checked .belief-text{color:var(--muted);text-decoration:line-through;}
.check-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border);cursor:pointer;}
.check-item:last-child{border-bottom:none;}
.check-box{width:20px;height:20px;border:2px solid var(--dim);border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.2s;font-size:11px;}
.check-item.checked .check-box{background:var(--accent);border-color:var(--accent);color:#000;}
.check-label{font-size:14px;font-weight:600;flex:1;}
.check-item.checked .check-label{color:var(--muted);text-decoration:line-through;}
.check-tag{font-size:10px;padding:2px 8px;border-radius:20px;font-family:'Space Mono',monospace;letter-spacing:1px;}
.tag-htf{background:rgba(0,229,160,0.1);color:var(--accent);border:1px solid rgba(0,229,160,0.2);}
.tag-entry{background:rgba(255,107,53,0.1);color:var(--accent2);border:1px solid rgba(255,107,53,0.2);}
.tag-risk{background:rgba(255,49,92,0.1);color:var(--danger);border:1px solid rgba(255,49,92,0.2);}
.tag-time{background:rgba(255,209,102,0.1);color:var(--warn);border:1px solid rgba(255,209,102,0.2);}
.tag-mind{background:rgba(150,150,255,0.1);color:#a0a0ff;border:1px solid rgba(150,150,255,0.2);}
.breath-circle{width:80px;height:80px;border-radius:50%;border:2px solid var(--accent);margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--accent);font-family:'Space Mono',monospace;letter-spacing:1px;background:rgba(0,229,160,0.05);}
.emotion-btn{padding:12px 8px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--muted);font-family:'Syne',sans-serif;font-size:12px;font-weight:600;cursor:pointer;transition:all 0.2s;text-align:center;}
.emotion-btn .emoji{font-size:20px;display:block;margin-bottom:4px;}
.emotion-btn:hover{border-color:var(--accent);color:var(--text);}
.emotion-btn.selected{border-color:var(--accent);background:rgba(0,229,160,0.08);color:var(--accent);}
.emotion-btn.selected-bad{border-color:var(--danger);background:rgba(255,49,92,0.08);color:var(--danger);}
.session-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;}
.session-stat{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px;}
.stat-label{font-size:10px;text-transform:uppercase;letter-spacing:2px;color:var(--muted);font-family:'Space Mono',monospace;margin-bottom:6px;}
.stat-value{font-size:22px;font-weight:800;font-family:'Space Mono',monospace;color:var(--text);}
.stat-value.accent{color:var(--accent);}.stat-value.warn{color:var(--warn);}.stat-value.danger{color:var(--danger);}
.rule-card{background:var(--bg);border-left:3px solid var(--accent);padding:12px 16px;border-radius:0 8px 8px 0;margin-bottom:10px;font-size:13px;line-height:1.6;color:var(--text);font-weight:600;}
.rule-card.warn{border-left-color:var(--warn);}.rule-card.danger{border-left-color:var(--danger);}.rule-card.info{border-left-color:#a0a0ff;}
.tl-item{display:flex;gap:14px;padding:10px 0;position:relative;}
.tl-item::before{content:'';position:absolute;left:19px;top:30px;bottom:-10px;width:1px;background:var(--border);}
.tl-item:last-child::before{display:none;}
.tl-dot{width:10px;height:10px;border-radius:50%;background:var(--dim);flex-shrink:0;margin-top:5px;border:2px solid var(--border);transition:all 0.3s;position:relative;z-index:1;margin-left:15px;}
.tl-item.active .tl-dot{background:var(--accent);border-color:var(--accent);box-shadow:0 0 10px rgba(0,229,160,0.5);}
.tl-item.done .tl-dot{background:var(--dim);border-color:var(--dim);}
.tl-time{font-family:'Space Mono',monospace;font-size:11px;color:var(--muted);letter-spacing:1px;}
.tl-item.active .tl-time{color:var(--accent);}
.tl-label{font-size:13px;font-weight:600;color:var(--muted);margin-top:1px;}
.tl-item.active .tl-label{color:var(--text);}
.question-block{background:rgba(255,107,53,0.05);border:1px solid rgba(255,107,53,0.2);border-radius:10px;padding:16px;margin-bottom:12px;}
.question-num{font-family:'Space Mono',monospace;font-size:10px;color:var(--accent2);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;}
.question-text{font-size:16px;font-weight:800;color:var(--text);margin-bottom:14px;line-height:1.3;}
.answer-btns{display:flex;gap:8px;}
#trade-verdict{display:none;padding:18px;border-radius:10px;text-align:center;font-size:18px;font-weight:800;letter-spacing:1px;margin-top:16px;animation:pop 0.3s ease;}
@keyframes pop{from{transform:scale(0.95);opacity:0;}to{transform:scale(1);opacity:1;}}
.verdict-go{background:rgba(0,229,160,0.1);border:2px solid var(--accent);color:var(--accent);}
.verdict-no{background:rgba(255,49,92,0.1);border:2px solid var(--danger);color:var(--danger);}
.verdict-sub{font-size:12px;font-weight:400;margin-top:6px;font-family:'Space Mono',monospace;opacity:0.8;letter-spacing:1px;}
#toast{position:fixed;bottom:24px;right:24px;background:var(--panel);border:1px solid var(--accent);border-radius:10px;padding:14px 18px;font-size:13px;font-weight:600;color:var(--accent);z-index:100;transform:translateY(80px);opacity:0;transition:all 0.3s;max-width:300px;font-family:'Space Mono',monospace;}
#toast.show{transform:translateY(0);opacity:1;}
#toast.warn-toast{border-color:var(--warn);color:var(--warn);}
#toast.danger-toast{border-color:var(--danger);color:var(--danger);}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:var(--dim);border-radius:4px;}

/* GUARDRAIL MODAL */
#guardrail-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:200;align-items:center;justify-content:center;}
#guardrail-modal.show{display:flex;}
.modal-box{background:var(--panel);border:2px solid var(--danger);border-radius:14px;padding:28px;max-width:400px;width:90%;text-align:center;}
.modal-icon{font-size:40px;margin-bottom:12px;}
.modal-title{font-size:18px;font-weight:800;color:var(--danger);margin-bottom:8px;}
.modal-msg{font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:20px;font-family:'Space Mono',monospace;}
.modal-btns{display:flex;gap:10px;justify-content:center;}

/* ANALYTICS */
.chart-wrap{position:relative;height:160px;margin:8px 0 4px;}
canvas{width:100%!important;}
.heatmap-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-top:8px;}
.hm-cell{border-radius:4px;height:36px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:9px;font-family:'Space Mono',monospace;color:var(--muted);transition:all 0.3s;}
.hm-label{font-size:9px;color:var(--muted);font-family:'Space Mono',monospace;text-align:center;margin-top:3px;}

/* DAY REVIEW LOG */
.day-review-item{border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:10px;cursor:pointer;transition:border-color 0.2s;}
.day-review-item:hover{border-color:var(--accent);}
.day-review-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.day-review-date{font-family:'Space Mono',monospace;font-size:12px;color:var(--accent);letter-spacing:1px;}
.day-review-pnl{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;}
.day-review-body{font-size:12px;color:var(--muted);line-height:1.6;display:none;}
.day-review-item.open .day-review-body{display:block;}

/* STREAK */
.streak-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;}
.streak-dot{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-family:'Space Mono',monospace;font-weight:700;}
</style>
</head>
<body>
<div class="container">

<header>
  <div>
    <div class="logo-title">Nifty <span>Trader</span></div>
    <div class="logo-sub">Session Assistant · Live</div>
  </div>
  <div style="text-align:right;">
    <div style="display:flex;align-items:center;gap:10px;justify-content:flex-end;">
      <button id="mute-btn" onclick="toggleMute()" style="background:none;border:1px solid var(--border);border-radius:6px;padding:4px 10px;color:var(--accent);font-family:'Space Mono',monospace;font-size:11px;cursor:pointer;letter-spacing:1px;">🔔 Sound</button>
      <div id="clock">--:--:--</div>
    </div>
    <div id="session-label">Loading...</div>
  </div>
</header>

<div class="tabs">
  <button class="tab active" onclick="switchTab('meditation',this)">🧘 Pre-Session</button>
  <button class="tab" onclick="switchTab('checklist',this)">✅ Pre-Entry</button>
  <button class="tab" onclick="switchTab('session',this)">📊 Session</button>
  <button class="tab" onclick="switchTab('journal',this)">📒 Journal</button>
  <button class="tab" onclick="switchTab('analytics',this)">📈 Analytics</button>
  <button class="tab" onclick="switchTab('ailog',this)">🤖 AI Log</button>
</div>

<!-- ══════════ PRE-SESSION ══════════ -->
<div id="tab-meditation" class="panel active">
  <div class="card">
    <div class="card-title">Morning Ritual · Belief Alignment</div>
    <div style="display:flex;flex-direction:column;align-items:center;padding:10px 0 20px;">
      <div class="breath-circle" id="breath-circle" style="transition:transform 0.6s ease,opacity 0.6s ease;">BREATHE</div>
      <div id="breath-text" style="font-family:'Space Mono',monospace;font-size:12px;color:var(--muted);letter-spacing:1px;">inhale... exhale... center yourself</div>
    </div>
  </div>
  <div class="card">
    <div class="card-title">Core Beliefs · Read & Accept</div>
    <div class="belief-item" onclick="toggleBelief(this)"><div class="belief-check">✓</div><div><div class="belief-text">Market can go any side — I have NO bias before open</div><div class="belief-sub">Release all overnight opinions. Fresh eyes only.</div></div></div>
    <div class="belief-item" onclick="toggleBelief(this)"><div class="belief-check">✓</div><div><div class="belief-text">Market will always give the best price — I have patience</div><div class="belief-sub">Don't chase. The pullback will come to you.</div></div></div>
    <div class="belief-item" onclick="toggleBelief(this)"><div class="belief-check">✓</div><div><div class="belief-text">I think in Daily context first, then 5-min execution</div><div class="belief-sub">Every 5-min candle is just a pixel in the daily picture.</div></div></div>
    <div class="belief-item" onclick="toggleBelief(this)"><div class="belief-check">✓</div><div><div class="belief-text">First 3 candles are low probability — I do not trade them</div><div class="belief-sub">9:15–9:30 IST is observation time, not trading time.</div></div></div>
    <div class="belief-item" onclick="toggleBelief(this)"><div class="belief-check">✓</div><div><div class="belief-text">I only buy pullbacks — I never chase breakouts</div><div class="belief-sub">Wait for the retracement. AVWAP confirms the entry.</div></div></div>
    <div class="belief-item" onclick="toggleBelief(this)"><div class="belief-check">✓</div><div><div class="belief-text">I always follow the 5-min price action terrain created by EMA</div><div class="belief-sub">EMA defines the terrain. I trade with it, never against it.</div></div></div>
    <div class="belief-item" onclick="toggleBelief(this)"><div class="belief-check">✓</div><div><div class="belief-text">I always ask 2 questions before every trade</div><div class="belief-sub">Can AVWAP fail? Can my 10pt SL hold?</div></div></div>
    <div class="progress-bar"><div class="progress-fill" id="belief-progress" style="width:0%"></div></div>
    <div class="progress-label" id="belief-label">0 / 7 beliefs acknowledged</div>
  </div>
  <div class="card">
    <div class="card-title">Temperature Check · Pre-Session</div>
    <div style="font-size:13px;color:var(--muted);margin-bottom:16px;">What is your mental temperature right now?</div>
    <div style="position:relative;height:10px;border-radius:10px;background:linear-gradient(90deg,#00e5a0,#ffd166,#ff6b35,#ff3a5c);margin-bottom:20px;">
      <div id="temp-indicator" style="position:absolute;top:-5px;left:5%;width:20px;height:20px;background:#fff;border-radius:50%;border:3px solid #111;transition:left 0.5s ease;transform:translateX(-50%);box-shadow:0 0 10px rgba(255,255,255,0.3);"></div>
    </div>
    <div style="display:flex;justify-content:space-between;font-family:'Space Mono',monospace;font-size:9px;color:var(--muted);letter-spacing:1px;margin-top:-12px;margin-bottom:18px;">
      <span style="color:var(--accent)">COLD</span><span style="color:var(--warn)">WARM</span><span style="color:var(--accent2)">HOT</span><span style="color:var(--danger)">BURNT</span>
    </div>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;">
      <div class="emotion-btn" onclick="selectTemp(this,0,'cold')"><span class="emoji">🧊</span>Cold & Calm<div style="font-size:10px;color:var(--accent);margin-top:3px;font-family:'Space Mono',monospace;">IDEAL</div></div>
      <div class="emotion-btn" onclick="selectTemp(this,35,'warm')"><span class="emoji">🌤️</span>Warm & Focused<div style="font-size:10px;color:var(--warn);margin-top:3px;font-family:'Space Mono',monospace;">GOOD</div></div>
      <div class="emotion-btn" onclick="selectTemp(this,67,'hot')"><span class="emoji">🔥</span>Overheated<div style="font-size:10px;color:var(--accent2);margin-top:3px;font-family:'Space Mono',monospace;">CAUTION</div></div>
      <div class="emotion-btn" onclick="selectTemp(this,100,'burnt')"><span class="emoji">💀</span>Burnt Out<div style="font-size:10px;color:var(--danger);margin-top:3px;font-family:'Space Mono',monospace;">DO NOT TRADE</div></div>
    </div>
    <div id="emotion-advice" style="margin-top:14px;padding:14px;border-radius:8px;font-size:13px;line-height:1.6;display:none;"></div>
    <hr style="border:none;border-top:1px solid var(--border);margin:16px 0;">
    <div class="card-title" style="margin-bottom:14px;">Pre-Session Conditions</div>
    <div class="check-item" onclick="toggleTempCheck(this)" id="tc-sleep"><div class="check-box">✓</div><div class="check-label">Last night's sleep was good quality</div><span class="check-tag tag-mind">SLEEP</span></div>
    <div class="check-item" onclick="toggleTempCheck(this)" id="tc-focus"><div class="check-box">✓</div><div class="check-label">Morning focus quality is sharp & clear</div><span class="check-tag tag-mind">FOCUS</span></div>
    <div class="check-item" onclick="toggleTempCheck(this)" id="tc-social"><div class="check-box">✓</div><div class="check-label">No social media scrolling this morning</div><span class="check-tag tag-time">CLEAN</span></div>
    <div class="check-item" onclick="toggleTempCheck(this)" id="tc-yt"><div class="check-box">✓</div><div class="check-label">No YouTube or content consumption today</div><span class="check-tag tag-time">CLEAN</span></div>
    <div class="progress-bar"><div class="progress-fill" id="temp-check-progress" style="width:0%"></div></div>
    <div class="progress-label" id="temp-check-label">0 / 4 conditions met</div>
    <div id="temp-check-warning" style="display:none;margin-top:12px;padding:12px 14px;border-radius:8px;background:rgba(255,49,92,0.07);border:1px solid rgba(255,49,92,0.2);font-size:12px;color:var(--danger);font-family:'Space Mono',monospace;line-height:1.6;"></div>
  </div>
</div>

<!-- ══════════ PRE-ENTRY ══════════ -->
<div id="tab-checklist" class="panel">
  <div class="card">
    <div class="card-title">Pre-Entry Breath · Box Breathing 4-4-4-4</div>
    <div style="font-size:13px;color:var(--muted);margin-bottom:18px;font-family:'Space Mono',monospace;line-height:1.6;">Sharpens attention and calms the nervous system before you execute.</div>
    <div style="display:flex;flex-direction:column;align-items:center;">
      <div style="position:relative;width:160px;height:160px;margin-bottom:18px;">
        <svg width="160" height="160" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">
          <circle cx="80" cy="80" r="68" fill="none" stroke="var(--border)" stroke-width="4"/>
          <circle id="pre-breath-arc" cx="80" cy="80" r="68" fill="none" stroke="var(--accent)" stroke-width="4" stroke-dasharray="427" stroke-dashoffset="427" stroke-linecap="round" style="transition:stroke-dashoffset 0.1s linear,stroke 0.5s ease;"/>
        </svg>
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
          <div id="pre-breath-phase" style="font-size:11px;font-family:'Space Mono',monospace;color:var(--muted);letter-spacing:2px;text-transform:uppercase;">READY</div>

// ── BREATHING ENGINE ───────────────────────────────────────────
const breathTimers={pre:null,post:null};const CIRC=427;
const prePhases=[{label:'INHALE',secs:4,arcDir:1},{label:'HOLD',secs:4,arcDir:0},{label:'EXHALE',secs:4,arcDir:-1},{label:'HOLD',secs:4,arcDir:0}];
const postPhases=[{label:'INHALE',secs:2,arcDir:1},{label:'SIP IN',secs:1,arcDir:1},{label:'EXHALE',secs:6,arcDir:-1},{label:'REST',secs:1,arcDir:0}];
const ROUNDS=4;
function startBreath(w){
  stopBreath(w);
  const phases=w==='pre'?prePhases:postPhases;
  const arcEl=document.getElementById(w+'-breath-arc'),phEl=document.getElementById(w+'-breath-phase'),cnEl=document.getElementById(w+'-breath-count'),rnEl=document.getElementById(w+'-breath-round'),dnEl=document.getElementById(w+'-breath-done');
  const col=w==='pre'?'var(--accent)':'#a0a0ff';
  dnEl.style.display='none';let round=1,pi=0,tick=0,off=CIRC;arcEl.style.strokeDashoffset=CIRC;
  function run(){const p=phases[pi];const prog=tick/p.secs;if(p.arcDir===1)off=CIRC*(1-prog);else if(p.arcDir===-1)off=CIRC*prog;arcEl.style.strokeDashoffset=off;arcEl.style.stroke=p.label==='EXHALE'?(w==='pre'?'#00b37a':'#7070ee'):col;phEl.textContent=p.label;cnEl.textContent=p.secs-tick;rnEl.textContent=`ROUND ${round} / ${ROUNDS}`;tick++;if(tick>p.secs){tick=0;pi++;if(pi>=phases.length){pi=0;round++;if(round>ROUNDS){clearInterval(breathTimers[w]);phEl.textContent='DONE';cnEl.textContent='✓';rnEl.textContent='';arcEl.style.strokeDashoffset=0;dnEl.style.display='block';return;}}}}
  run();breathTimers[w]=setInterval(run,1000);
}
function stopBreath(w){if(breathTimers[w]){clearInterval(breathTimers[w]);breathTimers[w]=null;}const a=document.getElementById(w+'-breath-arc');if(a)a.style.strokeDashoffset=CIRC;const ph=document.getElementById(w+'-breath-phase'),cn=document.getElementById(w+'-breath-count'),rn=document.getElementById(w+'-breath-round');if(ph)ph.textContent='READY';if(cn)cn.textContent='–';if(rn)rn.textContent='';}

// ── MORNING BREATH ANIMATION ────────────────────────────────────
const breathSteps=[{text:'inhale...',dur:2000},{text:'inhale again ↑',dur:1500},{text:'long exhale...',dur:6000},{text:'rest...',dur:2000}];
let bIdx=0;
function runBreath(){const s=breathSteps[bIdx];document.getElementById('breath-text').textContent=s.text;const c=document.getElementById('breath-circle');c.style.transform=s.text.startsWith('inhale')?(bIdx===0?'scale(1.1)':'scale(1.25)'):(s.text.startsWith('long')?'scale(0.9)':'scale(1)');c.style.opacity=s.text.startsWith('long')?'0.6':'1';bIdx=(bIdx+1)%breathSteps.length;setTimeout(runBreath,s.dur);}
runBreath();


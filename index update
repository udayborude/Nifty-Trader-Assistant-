// ── TOAST ──────────────────────────────────────────────────────
let audioMuted=false;
function showToast(msg,warn,snd){
  const t=document.getElementById('toast');t.textContent=msg;t.className=warn?'warn-toast show':'show';setTimeout(()=>t.className='',3500);
  if(!audioMuted&&snd)playAlert(snd);
  else if(!audioMuted&&warn)playAlert('warn');
  else if(!audioMuted&&!warn)playAlert('good');
}
function toggleMute(){audioMuted=!audioMuted;const b=document.getElementById('mute-btn');b.textContent=audioMuted?'🔇 Muted':'🔔 Sound';b.style.color=audioMuted?'var(--danger)':'var(--accent)';if(!audioMuted)playAlert('good');}

// ── AUDIO ALERTS ───────────────────────────────────────────────
let audioCtx=null;
function getAudioCtx(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();return audioCtx;}

function playTone(freq,dur,type='sine',vol=0.4){
  try{const ctx=getAudioCtx();const o=ctx.createOscillator();const g=ctx.createGain();o.connect(g);g.connect(ctx.destination);o.type=type;o.frequency.setValueAtTime(freq,ctx.currentTime);g.gain.setValueAtTime(vol,ctx.currentTime);g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+dur);o.start(ctx.currentTime);o.stop(ctx.currentTime+dur);}catch(e){}}

function playAlert(type){
  const ctx=getAudioCtx();
  if(type==='warn'){
    // Two-tone warning beep
    playTone(880,0.15,'square',0.3);
    setTimeout(()=>playTone(660,0.25,'square',0.3),180);
  } else if(type==='good'){
    // Rising pleasant chime
    playTone(523,0.15,'sine',0.35);
    setTimeout(()=>playTone(659,0.15,'sine',0.35),160);
    setTimeout(()=>playTone(784,0.3,'sine',0.35),320);
  } else if(type==='bell'){
    // Single bell
    playTone(1047,0.6,'sine',0.4);
    setTimeout(()=>playTone(1047,0.4,'sine',0.15),650);
  } else if(type==='danger'){
    // Urgent triple beep
    [0,220,440].forEach(d=>setTimeout(()=>playTone(440,0.18,'sawtooth',0.35),d));
  }
}


// ── ANALYTICS ──────────────────────────────────────────────────
let equityChart=null;
function renderAnalytics(){
  // Equity curve
  const sorted=[...trades].reverse();
  let cum=0;const labels=[],data=[];
  sorted.forEach((t,i)=>{cum+=(t.totalPnl||0);labels.push(`#${i+1} ${t.date}`);data.push(parseFloat(cum.toFixed(0)));});
  const eEl=document.getElementById('equity-chart'),eEmp=document.getElementById('equity-empty');
  if(!sorted.length){eEl.style.display='none';eEmp.style.display='block';}
  else{eEl.style.display='block';eEmp.style.display='none';
    if(equityChart)equityChart.destroy();
    equityChart=new Chart(eEl.getContext('2d'),{type:'line',data:{labels,datasets:[{label:'P&L',data,borderColor:'#00e5a0',backgroundColor:'rgba(0,229,160,0.08)',borderWidth:2,pointRadius:3,pointBackgroundColor:data.map(v=>v>=0?'#00e5a0':'#ff3a5c'),tension:0.3,fill:true}]},options:{responsive:true,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>`₹${ctx.raw}`}}},scales:{x:{display:false},y:{ticks:{color:'#4a5568',callback:v=>'₹'+v},grid:{color:'#1e2430'}}}}});
  }

  // Heatmap
  const hours={};for(let h=9;h<=15;h++)hours[h]={pnl:0,count:0};
  trades.forEach(t=>{
    const et=t.entryTime;
    if(!et||et==='—'||!/^\d{1,2}:\d{2}$/.test(et))return;
    const h=parseInt(et.split(':')[0],10);
    if(hours[h]!==undefined){hours[h].pnl+=(t.totalPnl||0);hours[h].count++;}
  });
  const hEl=document.getElementById('heatmap-wrap'),hEmp=document.getElementById('heatmap-empty');
  // Always render the heatmap grid; grey cells = no trades that hour
  hEmp.style.display='none';
  const maxAbs=Math.max(1,...Object.values(hours).map(v=>Math.abs(v.pnl)));
  hEl.innerHTML=`<div class="heatmap-grid">${Object.entries(hours).map(([h,v])=>{
    const intensity=v.count===0?0:Math.min(1,Math.abs(v.pnl)/maxAbs);
    const col=v.count===0?'var(--dim)':v.pnl>=0?`rgba(0,229,160,${0.15+0.85*intensity})`:`rgba(255,49,92,${0.15+0.85*intensity})`;
    const label=v.count>0?`${v.pnl>=0?'+':''}₹${Math.round(v.pnl)}`:'—';
    return `<div><div class="hm-cell" style="background:${col};" title="${h}:00 · ${v.count} trade(s) · ₹${Math.round(v.pnl)}">${label}</div><div class="hm-label">${h}:00</div></div>`;
  }).join('')}</div>
  <div style="display:flex;gap:16px;margin-top:10px;font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);">
    <span>⬛ No trades</span>
    <span style="color:var(--accent);">🟩 Profitable hour</span>
    <span style="color:var(--danger);">🟥 Loss hour</span>
  </div>`;

  // Discipline per day
  const byDay={};trades.forEach(t=>{if(!byDay[t.date])byDay[t.date]={trades:0,breaks:0,pnl:0};byDay[t.date].trades++;byDay[t.date].breaks+=t.breaks.length;byDay[t.date].pnl+=(t.totalPnl||0);});
  const dEl=document.getElementById('discipline-wrap'),dEmp=document.getElementById('discipline-empty');
  if(!Object.keys(byDay).length){dEl.innerHTML='';dEmp.style.display='block';}
  else{dEmp.style.display='none';
    dEl.innerHTML=Object.entries(byDay).map(([date,d])=>{
      const score=Math.max(0,100-d.breaks*20);const col=score>=80?'var(--accent)':score>=50?'var(--warn)':'var(--danger)';
      return `<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);">
        <div style="font-family:'Space Mono',monospace;font-size:11px;color:var(--muted);min-width:70px;">${date}</div>
        <div style="flex:1;height:8px;background:var(--dim);border-radius:4px;overflow:hidden;"><div style="height:100%;width:${score}%;background:${col};border-radius:4px;transition:width 0.5s;"></div></div>
        <div style="font-family:'Space Mono',monospace;font-size:12px;color:${col};min-width:36px;text-align:right;">${score}%</div>
        <div style="font-family:'Space Mono',monospace;font-size:11px;color:${d.pnl>=0?'var(--accent)':'var(--danger)'};min-width:64px;text-align:right;">${d.pnl>=0?'+':''}₹${Math.round(d.pnl)}</div>
      </div>`;
    }).join('');
  }

  // R:R Scatter
  let rrChart=null;
  const rrTrades=trades.filter(t=>t.entryPrice&&t.exitPrice&&t.sl);
  const rrEl=document.getElementById('rr-chart'),rrEmp=document.getElementById('rr-empty'),rrStats=document.getElementById('rr-stats');
  if(!rrTrades.length){rrEl.style.display='none';rrEmp.style.display='block';rrStats.style.display='none';}
  else{
    rrEl.style.display='block';rrEmp.style.display='none';
    const pts=rrTrades.map(t=>{
      const risk=Math.abs(t.entryPrice-t.sl);
      const reward=Math.abs(t.exitPrice-t.entryPrice);
      const rr=risk>0?parseFloat((reward/risk).toFixed(2)):0;
      const pnl=t.totalPnl||0;
      return {x:rr,y:pnl,r:t.result,label:`${t.type} ${t.date}\nR:R ${rr} · ₹${Math.round(pnl)}`};
    });
    const wins=pts.filter(p=>p.r==='WIN'),losses=pts.filter(p=>p.r==='LOSS');
    if(rrChart)rrChart.destroy();
    rrChart=new Chart(rrEl.getContext('2d'),{type:'scatter',data:{datasets:[
      {label:'Win',data:wins.map(p=>({x:p.x,y:p.y})),backgroundColor:'rgba(0,229,160,0.7)',pointRadius:7,pointHoverRadius:9},
      {label:'Loss',data:losses.map(p=>({x:p.x,y:p.y})),backgroundColor:'rgba(255,49,92,0.7)',pointRadius:7,pointHoverRadius:9}
    ]},options:{responsive:true,plugins:{legend:{labels:{color:'#4a5568',font:{family:'Space Mono'}}},tooltip:{callbacks:{label:ctx=>`R:R ${ctx.parsed.x} · ₹${ctx.parsed.y}`}}},scales:{
      x:{title:{display:true,text:'Risk:Reward Ratio →',color:'#4a5568',font:{family:'Space Mono',size:10}},ticks:{color:'#4a5568'},grid:{color:'#1e2430'},min:0},
      y:{title:{display:true,text:'P&L (₹) →',color:'#4a5568',font:{family:'Space Mono',size:10}},ticks:{color:'#4a5568',callback:v=>'₹'+v},grid:{color:'#1e2430'}}
    }}});
    // summary stats
    const avgRR=pts.reduce((s,p)=>s+p.x,0)/pts.length;
    const bestRR=Math.max(...pts.map(p=>p.x));
    const below1=pts.filter(p=>p.x<1).length;
    rrStats.style.display='flex';
    rrStats.innerHTML=[
      {label:'Avg R:R',val:avgRR.toFixed(2),col:'var(--accent)'},
      {label:'Best R:R',val:bestRR.toFixed(2),col:'var(--accent)'},
      {label:'Trades < 1R',val:below1,col:below1>pts.length/2?'var(--danger)':'var(--warn)'},
      {label:'Plotted Trades',val:pts.length,col:'var(--text)'}
    ].map(s=>`<div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 14px;flex:1;min-width:80px;"><div style="font-size:9px;font-family:'Space Mono',monospace;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px;">${s.label}</div><div style="font-size:18px;font-weight:800;font-family:'Space Mono',monospace;color:${s.col};">${s.val}</div></div>`).join('');
  }

  const sEl=document.getElementById('streak-wrap');
  if(!trades.length){sEl.innerHTML='<div style="text-align:center;color:var(--muted);font-family:Space Mono,monospace;font-size:12px;padding:20px 0;">Log trades to see streaks</div>';return;}
  const closed=trades.filter(t=>t.result!=='OPEN').reverse();
  let cur=0,curType='',longest=0,longestType='',streak=0;
  closed.forEach(t=>{if(t.result===curType)cur++;else{curType=t.result;cur=1;}if(cur>longest){longest=cur;longestType=curType;}});
  const last=closed[closed.length-1];if(last){curType=last.result;cur=0;for(let i=closed.length-1;i>=0;i--){if(closed[i].result===curType)cur++;else break;}}
  sEl.innerHTML=`<div style="display:flex;justify-content:space-around;margin-bottom:16px;">
    <div style="text-align:center;"><div class="stat-label">Current Streak</div><div class="stat-value ${cur>0&&curType==='WIN'?'accent':'danger'}">${cur} ${curType}</div></div>
    <div style="text-align:center;"><div class="stat-label">Best Streak</div><div class="stat-value accent">${longest} ${longestType}</div></div>
  </div>
  <div class="streak-row">${closed.slice(-20).map(t=>`<div class="streak-dot" style="background:${t.result==='WIN'?'rgba(0,229,160,0.15)':'rgba(255,49,92,0.15)'};color:${t.result==='WIN'?'var(--accent)':'var(--danger)'};border:1px solid ${t.result==='WIN'?'rgba(0,229,160,0.3)':'rgba(255,49,92,0.3)'};" title="${t.date}">${t.result==='WIN'?'W':'L'}</div>`).join('')}</div>
  <div style="font-size:10px;color:var(--muted);font-family:'Space Mono',monospace;margin-top:8px;">Last ${Math.min(20,closed.length)} closed trades →</div>`;
}

// ── AI DAILY REVIEW ────────────────────────────────────────────
async function generateDailyReview(){
  if(!trades.length){showToast('Log some trades first!',true);return;}
  const loadEl=document.getElementById('ai-loading'),todayEl=document.getElementById('ai-today');
  todayEl.innerHTML='';loadEl.style.display='block';

  // Build historical context from saved reviews
  let histContext='';
  try{
    if(window.storage){
      const keys=await window.storage.list('ailog:');
      if(keys&&keys.keys&&keys.keys.length){
        const recent=keys.keys.slice(-3);
        const reviews=await Promise.all(recent.map(k=>window.storage.get(k)));
        histContext='\n\nPREVIOUS AI REVIEWS (for comparison):\n'+reviews.filter(r=>r).map(r=>{const d=JSON.parse(r.value);return `[${d.date}]: ${d.summary}`;}).join('\n');
      }
    }
  }catch(e){}

  const today=todayStr();
  const todayTrades=trades.filter(t=>t.date===today);
  const allSummary=trades.slice(0,30).map((t,i)=>`Trade ${i+1} (${t.date}): ${t.type}, ${t.result}, Entry ₹${t.entryPrice}, Exit ₹${t.exitPrice||'open'}, P&L ₹${t.totalPnl!==null?Math.round(t.totalPnl):'open'}, Time: ${t.entryTime}→${t.exitTime}, Tags:[${t.rules.join(', ')}]${t.note?', Note:'+t.note:''}`).join('\n');

  const prompt=`You are a strict but caring trading coach for an Indian Nifty options trader. Today is ${today}.

TODAY'S TRADES (${todayTrades.length} trades):
${todayTrades.length?todayTrades.map(t=>`${t.type}, ${t.result}, Entry ₹${t.entryPrice}, Exit ₹${t.exitPrice||'open'}, P&L ₹${t.totalPnl!==null?Math.round(t.totalPnl):'open'}, Time:${t.entryTime}→${t.exitTime}, Tags:[${t.rules.join(', ')}]${t.note?', Note:'+t.note:''}`).join('\n'):'No trades today.'}

ALL RECENT TRADES (last 30):
${allSummary}
${histContext}

TRADER'S RULES:
- No trades in first 3 candles (9:15–9:30 IST)
- Only buy pullbacks via AVWAP, never chase breakouts
- SL = 10 points max, no exceptions
- Always check Daily EMA before entry
- Follow 5-min price action terrain created by EMA
- Think in Daily context, execute on 5-min

Provide a day-by-day coaching review with these exact sections:
**TODAY'S PERFORMANCE** — Quick summary of today's trades and P&L
**PATTERNS I SEE** — Recurring habits (good or bad) across all their trades
**COMPARED TO YESTERDAY** — How today compares (only if previous reviews exist)
**ONE THING TO FIX** — Single most important improvement for tomorrow
**TOMORROW'S INTENTION** — One sentence they should say to themselves tomorrow morning

Keep it under 250 words. Be direct. Reference actual data.`;

  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:prompt}]})});
    const data=await res.json();
    const text=data.content.map(b=>b.text||'').join('');
    loadEl.style.display='none';
    const html=text.replace(/\*\*(.+?)\*\*/g,'<strong style="color:var(--accent);">$1</strong>').replace(/\n\n/g,'<br><br>').replace(/\n/g,'<br>');
    todayEl.innerHTML=html;

    // Save review
    const summary=text.substring(0,300);
    try{if(window.storage)await window.storage.set('ailog:'+today,JSON.stringify({date:today,summary,full:text,ts:Date.now()}));}catch(e){}
    renderAIHistory();
    showToast('AI review saved for '+today,false);
  }catch(e){loadEl.style.display='none';todayEl.innerHTML='<span style="color:var(--danger);">Could not connect to AI. Check connection.</span>';}
}

async function renderAIHistory(){
  const card=document.getElementById('ai-history-card'),log=document.getElementById('ai-history-log');
  try{
    if(!window.storage){card.style.display='none';return;}
    const keys=await window.storage.list('ailog:');
    if(!keys||!keys.keys||!keys.keys.length){card.style.display='none';return;}
    card.style.display='block';
    const reviews=await Promise.all(keys.keys.reverse().map(k=>window.storage.get(k)));
    log.innerHTML=reviews.filter(r=>r).map(r=>{
      const d=JSON.parse(r.value);
      const html=d.full.replace(/\*\*(.+?)\*\*/g,'<strong style="color:var(--accent);">$1</strong>').replace(/\n\n/g,'<br><br>').replace(/\n/g,'<br>');
      return `<div class="day-review-item" onclick="this.classList.toggle('open')">
        <div class="day-review-header"><span class="day-review-date">📅 ${d.date}</span><span style="font-size:11px;color:var(--muted);font-family:'Space Mono',monospace;">tap to expand ▾</span></div>
        <div style="font-size:12px;color:var(--muted);font-family:'Space Mono',monospace;">${d.summary.substring(0,100)}...</div>
        <div class="day-review-body" style="margin-top:12px;font-size:13px;line-height:1.8;color:var(--text);">${html}</div>
      </div>`;
    }).join('');
  }catch(e){card.style.display='none';}
}

